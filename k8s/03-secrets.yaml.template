# This file is a TEMPLATE only — never commit real secrets to git.
# In CI/CD, secrets are injected via GitHub Actions secrets + kubectl.
# The CI pipeline runs: kubectl create secret generic app-secrets --from-literal=...

apiVersion: v1
kind: Secret
metadata:
  name: app-secrets
  namespace: aws-cost-estimator
type: Opaque
stringData:
  # Set via GitHub Actions secret: DATABASE_URL
  DATABASE_URL: "postgresql://USER:PASSWORD@RDS_ENDPOINT:5432/awscostdb"
